{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Copy JavaScript exports of current file",
            "type": "process",
            "command": "node",
            "args": [
                "${env:HOME}/.local/bin/get-ts-exports.mjs",
                "${file}"
            ],
            "presentation": {
                "reveal": "never",
                "echo": false,
                "focus": false,
                "panel": "dedicated"
            }
        }
    ]
}